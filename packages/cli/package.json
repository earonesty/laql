{
  "name": "lakeql-cli",
  "version": "0.0.4",
  "description": "lakeql command line: query, explain, inspect, write, compact",
  "keywords": [
    "lakehouse",
    "parquet",
    "iceberg",
    "object-storage",
    "cli"
  ],
  "author": "Erik Aronesty",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "lakeql": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepack": "pnpm -w build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/earonesty/lakeql.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "lakeql-core": "workspace:*",
    "lakeql-parquet": "workspace:*",
    "lakeql-sql": "workspace:*"
  },
  "devDependencies": {
    "lakeql-fixtures": "workspace:*"
  },
  "private": true
}
