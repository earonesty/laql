{
  "name": "@laql/cli",
  "version": "0.0.1",
  "description": "LaQL command line: query, explain, inspect, write, compact",
  "keywords": [
    "lakehouse",
    "parquet",
    "iceberg",
    "object-storage",
    "cli"
  ],
  "author": "Erik Aronesty",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "laql": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepack": "pnpm -w build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/earonesty/laql.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@laql/core": "workspace:*",
    "@laql/parquet": "workspace:*",
    "@laql/sql": "workspace:*"
  },
  "devDependencies": {
    "@laql/fixtures": "workspace:*"
  }
}
