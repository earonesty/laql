{
  "name": "lakeql-parquet",
  "version": "0.0.4",
  "description": "lakeql Parquet adapter: hyparquet reads, hyparquet-writer writes, pruning, projection",
  "keywords": [
    "parquet",
    "lakehouse",
    "object-storage",
    "hyparquet",
    "query-engine"
  ],
  "author": "Erik Aronesty",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepack": "pnpm -w build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/earonesty/lakeql.git",
    "directory": "packages/parquet"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "lakeql-core": "workspace:*",
    "hyparquet": "^1.26.0",
    "hyparquet-writer": "^0.15.6"
  },
  "devDependencies": {
    "lakeql-fixtures": "workspace:*",
    "lakeql-sql": "workspace:*"
  },
  "private": true
}
