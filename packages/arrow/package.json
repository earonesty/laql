{
  "name": "lakeql-arrow",
  "version": "0.0.5",
  "description": "lakeql Arrow output adapter: convert rows and column batches to Apache Arrow tables",
  "keywords": [
    "arrow",
    "apache-arrow",
    "lakeql",
    "duckdb-wasm",
    "query-engine"
  ],
  "author": "Erik Aronesty",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepack": "pnpm -w build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/earonesty/lakeql.git",
    "directory": "packages/arrow"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "apache-arrow": "^19.0.1",
    "lakeql-core": "workspace:*"
  },
  "private": true
}
