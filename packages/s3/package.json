{
  "name": "@laql/s3",
  "version": "0.0.2",
  "description": "lakeql S3-compatible object store adapter",
  "keywords": [
    "s3",
    "object-storage",
    "parquet",
    "lakehouse",
    "sigv4"
  ],
  "author": "Erik Aronesty",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepack": "pnpm -w build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/earonesty/lakeql.git",
    "directory": "packages/s3"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@laql/core": "workspace:*",
    "aws4fetch": "^1.0.20",
    "fast-xml-parser": "^5.9.0"
  },
  "private": true
}
