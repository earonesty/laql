{
  "name": "lakeql-opfs",
  "version": "0.0.5",
  "description": "lakeql OPFS persistent cache adapter for browser runtimes",
  "keywords": [
    "opfs",
    "browser",
    "cache",
    "duckdb-wasm",
    "lakeql"
  ],
  "author": "Erik Aronesty",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepack": "pnpm -w build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/earonesty/lakeql.git",
    "directory": "packages/opfs"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "lakeql-core": "workspace:*"
  },
  "private": true
}
