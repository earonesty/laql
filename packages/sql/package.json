{
  "name": "lakeql-sql",
  "version": "0.0.4",
  "description": "lakeql SQL dialect: parser and SQL-to-AST compiler",
  "keywords": [
    "sql",
    "parser",
    "lakehouse",
    "parquet",
    "query-engine"
  ],
  "author": "Erik Aronesty",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepack": "pnpm -w build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/earonesty/lakeql.git",
    "directory": "packages/sql"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "lakeql-core": "workspace:*",
    "pgsql-ast-parser": "^12.0.2"
  },
  "private": true
}
