{
  "name": "lakeql",
  "sideEffects": false,
  "version": "0.1.7",
  "description": "lakeql: lightweight TypeScript query engine for Iceberg + Parquet on object storage",
  "keywords": [
    "lakehouse",
    "parquet",
    "iceberg",
    "query-engine",
    "object-storage"
  ],
  "author": "Erik Aronesty",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "lakeql": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cloudflare": {
      "types": "./dist/cloudflare.d.ts",
      "default": "./dist/cloudflare.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepack": "pnpm -w build && pnpm --filter lakeql build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/earonesty/lakeql.git",
    "directory": "packages/lakeql"
  },
  "homepage": "https://lakeql.com",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@turf/boolean-contains": "^7.2.0",
    "@turf/boolean-intersects": "^7.2.0",
    "avsc": "^5.7.9",
    "aws4fetch": "^1.0.20",
    "fast-xml-parser": "^5.9.0",
    "fzstd": "^0.1.1",
    "h3-js": "^4.4.0",
    "hyparquet": "^1.26.0",
    "hyparquet-writer": "^0.15.6"
  },
  "devDependencies": {
    "lakeql-core": "workspace:*",
    "lakeql-fixtures": "workspace:*",
    "lakeql-http": "workspace:*",
    "lakeql-iceberg": "workspace:*",
    "lakeql-parquet": "workspace:*",
    "lakeql-r2": "workspace:*",
    "lakeql-s3": "workspace:*",
    "lakeql-sql": "workspace:*",
    "tsup": "^8.5.0"
  }
}
