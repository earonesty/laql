{
  "name": "@laql/http",
  "version": "0.0.1",
  "description": "LaQL HTTP range-read object store adapter",
  "keywords": [
    "http",
    "object-storage",
    "range-requests",
    "parquet",
    "lakehouse"
  ],
  "author": "Erik Aronesty",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepack": "pnpm -w build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/earonesty/laql.git",
    "directory": "packages/http"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@laql/core": "workspace:*"
  }
}
